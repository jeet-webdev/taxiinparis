// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id               Int      @id @default(autoincrement())
  pageName         String?  @map("page_name") @db.VarChar(50)
  title            String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(255) // Combined 'slag' and 'page_name' logic
  // Content Fields
  content          String?  @db.Text
  text             String?  @db.Text
  imageUpload      String?  @map("imageupload") @db.VarChar(255)
  // Service Highlights (from page_editor)
  secureBooking    String?  @map("secure_booking") @db.Text
  reliableService  String?  @map("reliable_service") @db.Text
  customerService  String?  @map("customer_service") @db.Text
  fairPrice        String?  @map("fair_price") @db.Text
  // SEO Metadata
  metaTitle        String?  @map("meta_title") @db.VarChar(255)
  metaDescription  String?  @map("meta_description") @db.Text
  metaKeywords     String?  @map("meta_keywords") @db.Text
  // Management
  status           String   @default("active") @db.VarChar(255)
  updatedAt        DateTime @updatedAt @default(now()) @map("updated_at")
 
  @@map("pages")
}

model Blog {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  text            String?  @db.Text
  imageUpload     String?  @map("image_upload") @db.VarChar(255)
  metaTitle       String?  @map("meta_title") @db.VarChar(255)
  metaDescription String?  @map("meta_description") @db.Text
  metaKeywords    String?  @map("meta_keywords") @db.Text
  status          String   @default("active") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @default(now()) @map("updated_at")

  @@map("blogs")
}

// Additional models for user management and authentication
// Roles for access control
enum Role {
  ADMIN
  EDITOR
  USER
}

model Account {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      Role      @default(USER)

  sessions  Session[]   // 🔁 reverse relation

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([role])
}

model Session {
  id        String    @id @default(uuid())

  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([accountId])
  @@index([expiresAt])
}