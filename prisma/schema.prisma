generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id                   Int      @id @default(autoincrement())
  pageName             String?  @map("page_name") @db.VarChar(50)
  title                String   @db.VarChar(255)
  slug                 String   @unique @db.VarChar(255)
  content              String?
  text                 String?
  imageUpload          String?  @map("imageupload") @db.VarChar(255)
  secureBooking        String?  @map("secure_booking")
  reliableService      String?  @map("reliable_service")
  customerService      String?  @map("customer_service")
  fairPrice            String?  @map("fair_price")
  metaTitle            String?  @map("meta_title") @db.VarChar(255)
  metaDescription      String?  @map("meta_description")
  metaKeywords         String?  @map("meta_keywords")
  status               String   @default("active") @db.VarChar(255)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")
  customerServiceTitle String?  @map("customer_service_title")
  fairPriceTitle       String?  @map("fair_price_title")
  reliableServiceTitle String?  @map("reliable_service_title")
  secureBookingTitle   String?  @map("secure_booking_title")
  imageAlt             String?  @map("imagealt") @db.VarChar(255)
  customerServiceIcon  String?
  fairPriceIcon        String?
  reliableServiceIcon  String?
  secureBookingIcon    String?

  @@map("pages")
}

model Blog {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  text            String?
  imageUpload     String?  @map("image_upload") @db.VarChar(255)
  metaTitle       String?  @map("meta_title") @db.VarChar(255)
  metaDescription String?  @map("meta_description")
  metaKeywords    String?  @map("meta_keywords")
  status          String   @default("active") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  bannerAlt       String?  @map("banner_alt") @db.VarChar(255)
  bannerImage     String?  @map("banner_upload") @db.VarChar(255)

  @@map("blogs")
}

model Account {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]

  @@index([role])
}

model Session {
  id        String   @id @default(uuid())
  accountId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model Footer {
  id            Int      @id @default(autoincrement())
  title         String?
  tagline       String?
  copyrightText String?
  email         String?
  phone         String?
  address       String?
  socialLinks   Json?
  navLinks      Json?
  appLinks      Json?
  paymentLinks  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  logoAlt       String?
  logoUrl       String?
}

model Feature {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  description  String
  createdAt    DateTime @default(now()) @map("created_at")
  buttonText   String?  @default("Explore") @db.VarChar(100)
  buttonLink   String?  @db.VarChar(500)
  category     String?  @db.VarChar(100)
  imageAlt     String?  @map("image_alt") @db.VarChar(255)
  imageUrl     String?  @map("image_url") @db.VarChar(500)
  isActive     Boolean  @default(true) @map("is_active")
  openInNewTab Boolean  @default(false) @map("open_in_new_tab")
  sortOrder    Int      @default(0) @map("sort_order")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("features")
}

model Category {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(150)
  slug          String         @unique @db.VarChar(150)
  createdAt     DateTime       @default(now()) @map("created_at")
  categoryPages CategoryPage[]

  @@map("categories")
}

model CategoryPage {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  categoryId      Int      @map("category_id")
  imageUpload     String?  @map("image_upload") @db.VarChar(255)
  imageAlt        String?  @map("image_alt") @db.VarChar(255)
  metaTitle       String?  @map("meta_title") @db.VarChar(255)
  metaDescription String?  @map("meta_description")
  metaKeywords    String?  @map("meta_keywords")
  content         Json?
  createdAt       DateTime @default(now()) @map("created_at")
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("category_pages")
}

enum Role {
  ADMIN
  EDITOR
  USER
}
