generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id               Int      @id @default(autoincrement())
  pageName         String?  @map("page_name") @db.VarChar(50)
  title            String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(255)
  content          String?
  text             String?
  imageUpload      String?  @map("imageupload") @db.VarChar(255)
  metaTitle        String?  @map("meta_title") @db.VarChar(255)
  metaDescription  String?  @map("meta_description")
  metaKeywords     String?  @map("meta_keywords")
  status           String   @default("active") @db.VarChar(255)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  imageAlt         String?  @map("imagealt") @db.VarChar(255)
  heroButtonLink   String?  @map("hero_button_link") @db.VarChar(255)
  heroButtonText   String?  @map("hero_button_text") @db.VarChar(100)
  heroCard1Title   String?  @map("hero_card1_title") @db.VarChar(100)
  heroCard2Title   String?  @map("hero_card2_title") @db.VarChar(100)
  heroCard3Title   String?  @map("hero_card3_title") @db.VarChar(100)
  heroCardFootnote String?  @map("hero_card_footnote") @db.VarChar(255)
  heroDescription  String?  @map("hero_description")
  heroPoint1       String?  @map("hero_point_1") @db.VarChar(100)
  heroPoint2       String?  @map("hero_point_2") @db.VarChar(100)
  heroPoint3       String?  @map("hero_point_3") @db.VarChar(100)
  heroSubtitle     String?  @map("hero_subtitle") @db.VarChar(255)
  heroColorTitle   String?  @map("hero_title") @db.VarChar(255)
  heroTrustText    String?  @map("hero_trust_text") @db.VarChar(255)

  @@map("pages")
}

model Blog {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  text            String?
  imageUpload     String?  @map("image_upload") @db.VarChar(255)
  metaTitle       String?  @map("meta_title") @db.VarChar(255)
  metaDescription String?  @map("meta_description")
  metaKeywords    String?  @map("meta_keywords")
  status          String   @default("active") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  bannerAlt       String?  @map("banner_alt") @db.VarChar(255)
  bannerImage     String?  @map("banner_upload") @db.VarChar(255)
  ctaBtnLink      String?  @default("https://portail.driverconnect.fr/vtc-fils/template?DS=1&tkn=00001_2769650_-1157023572_1772012786065") @map("cta_btn_link") @db.VarChar(500)
  ctaBtnText      String?  @default("Book Now") @map("cta_btn_text") @db.VarChar(100)

  @@map("blogs")
}

model Account {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]

  @@index([role])
}

model Session {
  id        String   @id @default(uuid())
  accountId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model Footer {
  id            Int      @id @default(autoincrement())
  title         String?
  tagline       String?
  copyrightText String?
  email         String?
  phone         String?
  address       String?
  socialLinks   Json?
  navLinks      Json?
  appLinks      Json?
  paymentLinks  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  logoAlt       String?
  logoUrl       String?
  mobileLogoAlt String?  @map("mobile_logo_alt")
  mobileLogoUrl String?  @map("mobile_logo_url")
  btnLink       String?
  btnText       String?
  whatsapp      String?
  showBtn       Boolean  @default(true)
  headerPhone   String?  @map("header_phone")
  showPhone     Boolean  @default(true) @map("show_phone")
}

model Feature {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  description  String
  createdAt    DateTime @default(now()) @map("created_at")
  buttonText   String?  @default("Explore") @db.VarChar(100)
  buttonLink   String?  @db.VarChar(500)
  category     String?  @db.VarChar(100)
  imageAlt     String?  @map("image_alt") @db.VarChar(255)
  imageUrl     String?  @map("image_url") @db.VarChar(500)
  isActive     Boolean  @default(true) @map("is_active")
  openInNewTab Boolean  @default(false) @map("open_in_new_tab")
  sortOrder    Int      @default(0) @map("sort_order")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  mainTitle    String?

  @@map("features")
}

model Category {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(150)
  slug          String         @unique @db.VarChar(150)
  createdAt     DateTime       @default(now()) @map("created_at")
  categoryPages CategoryPage[]

  @@map("categories")
}

model CategoryPage {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  categoryId      Int      @map("category_id")
  imageUpload     String?  @map("image_upload") @db.VarChar(255)
  imageAlt        String?  @map("image_alt") @db.VarChar(255)
  metaTitle       String?  @map("meta_title") @db.VarChar(255)
  metaDescription String?  @map("meta_description")
  metaKeywords    String?  @map("meta_keywords")
  content         Json?
  createdAt       DateTime @default(now()) @map("created_at")
  ctaBtnLink      String?  @default("https://portail.driverconnect.fr/vtc-fils/template?DS=1&tkn=00001_2769650_-1157023572_1772012786065") @map("cta_btn_link") @db.VarChar(255)
  ctaBtnText      String?  @default("Book Your Transfer Now") @map("cta_btn_text") @db.VarChar(100)
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("category_pages")
}

model SiteSetting {
  id           String   @id @default("singleton")
  smtpHost     String?  @map("smtp_host") @db.VarChar(255)
  smtpPort     Int?     @map("smtp_port")
  smtpUser     String?  @map("smtp_user") @db.VarChar(255)
  smtpPassword String?  @map("smtp_password") @db.VarChar(255)
  contactEmail String?  @map("contact_email") @db.VarChar(255)
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model GoogleSettings {
  id           Int      @id @default(1)
  clientId     String
  clientSecret String
  refreshToken String
  accountId    String
  locationId   String
  updatedAt    DateTime @updatedAt

  @@map("google_settings")
}

model GoogleReview {
  id                Int       @id @default(autoincrement())
  review_id         String?
  author_name       String?
  profile_photo_url String?
  rating            Int?
  review_text       String?
  review_time       String?   @db.VarChar(50)
  created_at        DateTime? @default(now())

  @@map("google_reviews")
}

enum Role {
  ADMIN
  EDITOR
  USER
}
